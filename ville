import os
import unicodedata
from collections import Counter


def remover_acentos(texto):
    return ''.join(
        c for c in unicodedata.normalize('NFD', texto)
        if unicodedata.category(c) != 'Mn'
    )


exames = {
    "ULTRASSOM": 166.00,
    "ELETROCARDIOGRAMA": 140.00,
    "ECOCARDIOGRAMA": 230.00,
    "CULTURA E ANTIBIOGRAMA": 132.00,
