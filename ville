total = 0
selecionados = []

while True:

    os.system('cls' if os.name == 'nt' else 'clear')

    print("=== VILLE ===")
    print("DIGITE O EXAME")
    print("DIGITE 'REMOVER' PARA EXCLUIR EXAME")
    print("DIGITE 'NOVO' PARA LIMPAR O ORÇAMENTO\n")

    if selecionados:

        contador = Counter(nome for nome, _ in selecionados)

        print("ORÇAMENTO:")

        for nome, qtd in contador.items():

            preco = exames[nome]
            subtotal = preco * qtd

            if qtd > 1:
                print(f"{nome} ({qtd}x): R$ {subtotal:.2f}")
            else:
                print(f"{nome}: R$ {subtotal:.2f}")

    print(f"\nTOTAL: R$ {total:.2f}\n")

    busca = input(">> ").strip().upper()

    # NOVO ORÇAMENTO
    if busca == "NOVO":

        selecionados.clear()
        total = 0

        input("\nNovo orçamento iniciado! Pressione ENTER...")
        continue

    # REMOVER EXAME
    elif busca == "REMOVER":

        if not selecionados:
            input("\nNenhum exame no orçamento. ENTER...")
            continue

        remover = input(
            "\nDigite o exame para remover: "
        ).strip().upper()

        remover_sem_acento = remover_acentos(remover)

        encontrados = [
            (nome, preco)
            for nome, preco in selecionados
            if remover_sem_acento in remover_acentos(nome.upper())
        ]

        if encontrados:

            nome, preco = encontrados[0]

            selecionados.remove((nome, preco))
            total -= preco

            input(f"\n1x {nome} removido! ENTER...")

        else:
            input("\nExame não encontrado. ENTER...")

        continue

    # BUSCA DE EXAMES
    busca_sem_acento = remover_acentos(busca)

    encontrados = [
        nome
        for nome in exames
        if busca_sem_acento in remover_acentos(nome.upper())
    ]

    if len(encontrados) == 1:

        nome = encontrados[0]
        preco = exames[nome]

        total += preco
        selecionados.append((nome, preco))

    elif len(encontrados) > 1:

        print("\nMais de um exame encontrado:\n")

        for i, nome in enumerate(encontrados, 1):
            print(f"{i} - {nome}")

        escolha = input("\nEscolha o número: ")

        if escolha.isdigit() and 1 <= int(escolha) <= len(encontrados):

            nome = encontrados[int(escolha) - 1]
            preco = exames[nome]

            total += preco
            selecionados.append((nome, preco))

    else:

        input("\nNenhum exame encontrado. ENTER...")
